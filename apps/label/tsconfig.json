{
  "compilerOptions": {
    "target": "es2020",
    "jsx": "preserve",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["./src/*"],
      "@image-taxonomy-labeler/shared/services/*": ["../../packages/shared/src/services/*"],
      "@image-taxonomy-labeler/shared/plugins/*": ["../../packages/shared/src/plugins/*"],
      "@image-taxonomy-labeler/shared/stores/*": ["../../packages/shared/src/stores/*"],
      "@image-taxonomy-labeler/shared/assets/*": ["../../packages/shared/assets/*"]
    },
    "resolveJsonModule": true,
    "types": [
      "vite/client",
      "vite-plugin-pages/client",
      "unplugin-vue-macros/macros-global"
    ],
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "exclude": ["dist", "node_modules", "eslint.config.js"]
}
